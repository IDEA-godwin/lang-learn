# Required — Supabase project credentials
# Find these in: Supabase Dashboard → Project Settings → API → API Keys
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional — Enable third-party OAuth buttons (set to "true" to show)
# Requires corresponding provider config in Supabase Dashboard → Authentication → Providers
# VITE_ENABLE_GOOGLE_AUTH=true
# VITE_ENABLE_APPLE_AUTH=true
